{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "booth-notification-dispatcher",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-29",
  "workers_dev": false,
  "observability": {
    "enabled": true
  },
  "secrets": {
    "required": ["GITHUB_TOKEN"]
  },
  "triggers": {
    "crons": ["0 * * * *"]
  }
}
